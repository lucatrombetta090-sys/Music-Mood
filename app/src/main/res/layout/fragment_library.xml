<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="14dp"
        android:paddingTop="16dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="La tua musica"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:letterSpacing="-0.02"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleView"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="⊞"
            android:textSize="17sp"
            app:backgroundTint="@color/elevated"
            android:textColor="@color/subtext"
            app:cornerRadius="18dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Scansiona"
            android:textSize="12sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            app:backgroundTint="#6C63FF"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="17dp"/>
    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="2dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@drawable/search_bg"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cerca…"
            android:textSize="14sp"
            android:textColor="@color/text"
            android:textColorHint="@color/subtext"
            android:background="@null"
            android:inputType="text"
            android:imeOptions="actionSearch"/>

        <!-- Bottone filtri dentro search bar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilter"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Filtri"
            android:textSize="11sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            app:backgroundTint="@color/elevated"
            android:textColor="@color/subtext"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cornerRadius="15dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>

    <!-- ── TABS: Brani / Cartelle / Artisti / Anno ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/tabRow"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tabBrani"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Brani"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="20dp"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tabCartelle"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Cartelle"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="20dp"
                android:textColor="#555570"/>

            <TextView
                android:id="@+id/tabArtisti"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Artisti"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="20dp"
                android:textColor="#555570"/>

            <TextView
                android:id="@+id/tabAnno"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Anno"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="#555570"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Tab indicator line -->
    <View
        android:id="@+id/tabIndicator"
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:layout_marginStart="16dp"
        android:background="#6C63FF"/>

    <!-- Mood chips (solo tab Brani) -->
    <HorizontalScrollView
        android:id="@+id/moodChipScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipMoodRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"/>
    </HorizontalScrollView>

    <!-- Progress -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressScan"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:visibility="gone"
        app:trackColor="@color/elevated"
        app:indicatorColor="#6C63FF"/>

    <!-- Status + count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="@color/subtext"
            android:text=""/>

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/subtext"
            android:text=""/>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Nessun brano trovato"
        android:textColor="@color/subtext"
        android:textSize="14sp"
        android:visibility="gone"/>

    <!-- Main RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSongs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

</LinearLayout>
