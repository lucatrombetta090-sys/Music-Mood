<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:minHeight="600dp">

        <!-- Stato vuoto -->
        <TextView
            android:id="@+id/tvNoSong"
            android:layout_width="match_parent"
            android:layout_height="600dp"
            android:text="Nessun brano selezionato&#10;&#10;Vai in Libreria e tocca un brano"
            android:textColor="@color/subtext"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingExtra="8dp"
            android:visibility="visible"/>

        <!-- Contenuto player -->
        <LinearLayout
            android:id="@+id/playerContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- ── ARTWORK ── -->
            <FrameLayout
                android:id="@+id/artworkBg"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="4dp"
                android:elevation="12dp">

                <!-- Copertina vera -->
                <ImageView
                    android:id="@+id/ivArtwork"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/artwork_bg"
                    android:clipToOutline="true"
                    android:visibility="invisible"/>

                <!-- Placeholder lettera -->
                <LinearLayout
                    android:id="@+id/tvArtworkLetter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/artwork_bg">

                    <TextView
                        android:id="@+id/tvArtworkLetterChar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="80sp"
                        android:textStyle="bold"
                        android:textColor="#30304A"
                        android:text="♪"/>
                </LinearLayout>

                <!-- Download copertina — cerchio in basso a destra -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadCover"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="10dp"
                    android:text="⬇"
                    android:textSize="14sp"
                    app:backgroundTint="#CC080810"
                    android:textColor="#9999CC"
                    app:cornerRadius="20dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:elevation="8dp"
                    android:visibility="gone"/>

            </FrameLayout>

            <!-- ── TITOLO + ARTISTA + MOOD ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPlayerTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:letterSpacing="-0.02"/>

                    <TextView
                        android:id="@+id/tvPlayerArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/subtext"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Mood pill -->
                <TextView
                    android:id="@+id/tvPlayerMood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/mood_pill_bg"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Genere + BPM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPlayerGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/subtext"
                    android:text="—"/>

                <TextView
                    android:id="@+id/tvPlayerTempo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/subtext"
                    android:layout_marginStart="14dp"
                    android:text=""/>
            </LinearLayout>

            <!-- ── SEEK BAR ── -->
            <com.google.android.material.slider.Slider
                android:id="@+id/seekSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="4dp"
                android:valueFrom="0"
                android:valueTo="1"
                android:value="0"
                app:trackColorActive="#6C63FF"
                app:trackColorInactive="#252538"
                app:thumbColor="#FFFFFF"
                app:thumbRadius="7dp"
                app:trackHeight="4dp"
                app:labelBehavior="gone"
                app:haloRadius="14dp"/>

            <!-- Tempi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:layout_marginTop="-8dp">

                <TextView android:id="@+id/tvTime"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp"
                    android:textColor="@color/subtext" android:text="0:00"/>
                <TextView android:id="@+id/tvDuration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/subtext" android:text="0:00"/>
            </LinearLayout>

            <!-- ── CONTROLLI PRINCIPALI ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical">

                <!-- Shuffle -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShuffle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_weight="0"
                    android:text="🔀"
                    android:textSize="18sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/subtext"
                    android:alpha="0.35"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <!-- Prev -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrev"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="⏮"
                    android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/text"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <!-- Play — grande cerchio viola -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlay"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    app:backgroundTint="#6C63FF"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:elevation="6dp"/>

                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <!-- Next -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="⏭"
                    android:textSize="26sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/text"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <!-- Loop -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoop"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="🔁"
                    android:textSize="18sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/subtext"
                    android:alpha="0.35"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>

            <!-- ── VOLUME ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="6dp"
                android:paddingBottom="16dp"
                android:gravity="center_vertical">

                <TextView android:text="🔈"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="14sp" android:textColor="@color/subtext"/>

                <com.google.android.material.slider.Slider
                    android:id="@+id/volSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:value="80"
                    app:trackColorActive="#8888BB"
                    app:trackColorInactive="#252538"
                    app:thumbColor="#AAAACC"
                    app:thumbRadius="5dp"
                    app:trackHeight="3dp"
                    app:labelBehavior="gone"/>

                <TextView android:text="🔊"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="14sp" android:textColor="@color/subtext"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
